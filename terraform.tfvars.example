# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit real secrets.

aws_region   = "us-east-1"
environment  = "dev"
cluster_name = "my-eks-platform"

cluster_version = "1.29"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-east-1a", "us-east-1b", "us-east-1c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
single_nat_gateway   = false   # set true to save cost in non-prod

node_instance_types = ["m5.xlarge"]
node_min_size       = 1
node_desired_size   = 2
node_max_size       = 10

enable_monitoring      = true
grafana_admin_password = "REPLACE_WITH_STRONG_PASSWORD"  # min 12 chars

tags = {
  Owner   = "platform-team"
  CostCenter = "engineering"
}
